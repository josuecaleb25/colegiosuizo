# Configuración para Render
# Copia este archivo y configura las variables en Render

# Django
SECRET_KEY=tu-secret-key-super-segura-aqui-cambiar-en-produccion
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos (Render lo proporciona automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# QR
QR_EXPIRATION_MINUTES=10

# Render (se configura automáticamente)
RENDER_EXTERNAL_HOSTNAME=tu-app.onrender.com
