<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:background="@drawable/bg_comunicado_border"
    app:cardBackgroundColor="@android:color/transparent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <!-- Banner: Ocupa TODO el card si está visible -->
        <ImageView
            android:id="@+id/iv_banner_comunicado"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Contenedor de texto -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_texto_comunicado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Título del comunicado en ROJO -->
            <TextView
                android:id="@+id/tv_titulo_comunicado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Título del Comunicado"
                android:textColor="#BA1924"
                android:textSize="15sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:fontFamily="@font/poppinssemibold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tv_hora_comunicado"/>

            <!-- Hora del comunicado (arriba a la derecha) -->
            <TextView
                android:id="@+id/tv_hora_comunicado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="10:30 AM"
                android:textColor="#9BA8AB"
                android:textSize="11sp"
                android:fontFamily="@font/poppinsmedium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Emisor del comunicado (pequeño, debajo del título) -->
            <TextView
                android:id="@+id/tv_emisor_comunicado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Administración"
                android:textColor="#9BA8AB"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:fontFamily="@font/poppinsmedium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_titulo_comunicado"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Fecha y destinatario (usado en historial) -->
            <TextView
                android:id="@+id/tv_fecha_destinatario"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="#9BA8AB"
                android:textSize="10sp"
                android:fontFamily="@font/poppinsregular"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_emisor_comunicado"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_contenido_comunicado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Cuerpo del mensaje..."
                android:textColor="#5E5F60"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:fontFamily="@font/poppinsregular"
                app:layout_constraintTop_toBottomOf="@+id/tv_fecha_destinatario"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/btn_ver_mas_comunicado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver más"
                android:textColor="#BA1924"
                android:textSize="12sp"
                android:fontFamily="@font/poppinssemibold"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/tv_contenido_comunicado"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Tag de Salón -->
            <TextView
                android:id="@+id/tv_tag_salon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Salón: 4to A"
                android:textColor="#BCC1CD"
                android:textSize="10sp"
                android:fontFamily="@font/poppinsmedium"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@+id/btn_ver_mas_comunicado"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Estado (solo visible en historial, anclado al fondo izquierdo) -->
        <TextView
            android:id="@+id/tv_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="14dp"
            android:text="Enviado"
            android:textColor="#4CAF50"
            android:textSize="10sp"
            android:fontFamily="@font/poppinsmedium"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_estado_enviado"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Botón de opciones (solo visible en historial, esquina superior derecha) -->
        <ImageView
            android:id="@+id/btn_opciones"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_more_vert"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:visibility="gone"
            app:tint="#5E5F60"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
