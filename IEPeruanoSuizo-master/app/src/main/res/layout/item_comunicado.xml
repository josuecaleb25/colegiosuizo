<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_comunicado"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Botón de opciones (3 puntos) - Ahora en la esquina superior derecha -->
        <ImageView
            android:id="@+id/btn_opciones"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_more_vert"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:visibility="gone"
            app:tint="#5E5F60"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo IEPS -->
        <ImageView
            android:id="@+id/iv_logo_ieps"
            android:layout_width="45dp"
            android:layout_height="28dp"
            android:src="@drawable/logoie"
            android:scaleType="fitCenter"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@+id/btn_opciones"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Título del comunicado -->
        <TextView
            android:id="@+id/tv_titulo_comunicado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:text="Título del Comunicado"
            android:textColor="#BA1924"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="@font/poppinssemibold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/iv_logo_ieps"/>

        <!-- Fecha y destinatario -->
        <TextView
            android:id="@+id/tv_fecha_destinatario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Enviado 2026-05-13 para Todos"
            android:textColor="#9BA8AB"
            android:textSize="10sp"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_titulo_comunicado"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Contenido del comunicado -->
        <TextView
            android:id="@+id/tv_contenido_comunicado"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Cuerpo del mensaje del comunicado..."
            android:textColor="#5E5F60"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:maxLines="4"
            android:ellipsize="end"
            android:fontFamily="@font/poppinsregular"
            app:layout_constraintTop_toBottomOf="@+id/tv_fecha_destinatario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Ver más -->
        <TextView
            android:id="@+id/btn_ver_mas_comunicado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver más"
            android:textColor="#BA1924"
            android:textSize="12sp"
            android:fontFamily="@font/poppinsmedium"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="4dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_contenido_comunicado"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Estado del comunicado -->
        <TextView
            android:id="@+id/tv_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Enviado"
            android:textColor="#4CAF50"
            android:textSize="11sp"
            android:fontFamily="@font/poppinsmedium"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_estado_enviado"
            app:layout_constraintTop_toBottomOf="@+id/btn_ver_mas_comunicado"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>