<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/tv_badge_nombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Evaluación"
        android:textColor="#141A1E"
        android:textSize="14sp"
        android:fontFamily="@font/pontanoregular" />

    <TextView
        android:id="@+id/tv_badge_nota"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="--"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="@font/leaguespartanbold"
        android:background="@drawable/badge_calificacion"
        android:paddingHorizontal="24dp"
        android:paddingVertical="6dp" />

</LinearLayout>
