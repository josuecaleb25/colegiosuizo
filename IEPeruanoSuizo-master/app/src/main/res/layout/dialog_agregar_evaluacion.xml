<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nombre de la evaluación"
        android:textColor="#5E5F60"
        android:textSize="13sp"
        android:fontFamily="@font/pontanoregular"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_nombre_evaluacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Examen parcial, Tarea 1, etc."
        android:inputType="text"
        android:textSize="14sp"
        android:fontFamily="@font/pontanoregular"
        android:padding="12dp"
        android:background="@drawable/input_border_selector"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calificación (0-20) - Opcional"
        android:textColor="#5E5F60"
        android:textSize="13sp"
        android:fontFamily="@font/pontanoregular"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/et_calificacion_nueva"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Dejar vacío si aún no tiene nota"
        android:inputType="number"
        android:maxLength="2"
        android:textSize="14sp"
        android:fontFamily="@font/pontanoregular"
        android:padding="12dp"
        android:background="@drawable/input_border_selector" />

</LinearLayout>
