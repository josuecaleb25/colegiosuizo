<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:paddingHorizontal="24dp">

    <!-- Barra de Navegación Superior -->
    <LinearLayout
        android:id="@+id/layout_top_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_atras_detalle"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="0dp"
            android:text="Atrás"
            android:textColor="#BA1924"
            android:textSize="14sp"
            android:fontFamily="@font/pontanomedium"
            app:icon="@drawable/righticon"
            app:iconPadding="4dp"
            app:iconSize="13dp"
            app:iconTint="#BA1924"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <View
            android:layout_width="1dp"
            android:layout_height="16dp"
            android:layout_marginHorizontal="12dp"
            android:background="#D1D1D1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pontanomedium"
            android:text="Estudiantes"
            android:textColor="#5E5F60"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginHorizontal="6dp"
            android:src="@drawable/chvronlefticon"
            android:alpha="0.6"
            app:tint="#141A1E" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pontanomedium"
            android:text="calificación"
            android:textColor="#141A1E"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Info del Estudiante Seleccionado -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_estudiante_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_nav">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/iv_foto_estudiante"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:src="@drawable/emptyphoto"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage" />

        <TextView
            android:id="@+id/tv_nombre_estudiante"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/leaguespartanmedium"
            android:text="Estudiante lorem"
            android:textColor="#141A1E"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@id/iv_foto_estudiante"
            app:layout_constraintEnd_toStartOf="@+id/card_promedio_total"
            app:layout_constraintStart_toEndOf="@id/iv_foto_estudiante"
            app:layout_constraintTop_toTopOf="@id/iv_foto_estudiante" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_promedio_total"
            android:layout_width="70dp"
            android:layout_height="35dp"
            app:cardBackgroundColor="#141A1E"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tv_promedio_total"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="--"
                android:textColor="@android:color/white"
                android:fontFamily="@font/pontanomedium"
                android:textSize="16sp" />
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Cabeceras de Tabla -->
    <TextView
        android:id="@+id/tv_label_elemento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/pontanomedium"
        android:text="Nombre de elemento"
        android:textColor="#141A1E"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_estudiante_info" />

    <TextView
        android:id="@+id/tv_label_calificacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/pontanomedium"
        android:text="Calificacion"
        android:textColor="#141A1E"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_label_elemento" />

    <!-- Lista de Evaluaciones -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progress_calificaciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="#BA1924"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_elemento" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_evaluaciones_estudiante"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_elemento"
        tools:listitem="@layout/item_calificacion_fila" />

</androidx.constraintlayout.widget.ConstraintLayout>
