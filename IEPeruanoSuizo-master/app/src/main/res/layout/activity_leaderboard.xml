<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header con botón de regreso y título Ranking -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/btn_back"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="?attr/homeContentBackground"
                app:cardCornerRadius="15dp"
                app:cardElevation="0dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@drawable/righticon"
                    app:tint="@color/text_white" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tv_ranking_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/potanosansbold"
                android:text="Ranking"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="18sp"
                android:layout_marginStart="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/menu_month_layout"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/menu_month_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:minWidth="100dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="#BA1924"
                app:boxStrokeWidth="1dp"
                app:endIconTint="@color/text_gray"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:textColor="@color/text_white"
                    android:textSize="12sp"
                    android:singleLine="true"
                    android:paddingVertical="8dp"
                    android:gravity="center_vertical"
                    android:background="@android:color/transparent"
                    android:dropDownHeight="160dp"
                    tools:text="Junio 2026" />
            </com.google.android.material.textfield.TextInputLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Hidden legacy views -->
    <Spinner
        android:id="@+id/spinner_month"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />
    <TextView
        android:id="@+id/tv_streak_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <!-- 2. HIGH contrast Navigation Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_tab_background"
        android:padding="4dp">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout_leaderboard"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="@android:color/transparent"
            app:tabIndicatorHeight="2dp"
            app:tabIndicatorColor="#BA1924"
            app:tabSelectedTextColor="#BA1924"
            app:tabTextColor="@color/text_gray"
            app:tabRippleColor="@null"
            app:tabMode="fixed"
            app:tabGravity="fill">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asistencia" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puntualidad" />
        </com.google.android.material.tabs.TabLayout>
    </LinearLayout>

    <!-- Classroom Filter Switch (Students) -->
    <LinearLayout
        android:id="@+id/layout_classroom_filter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="@drawable/bg_card_row">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_person_placeholder"
            app:tint="@color/text_gray"
            android:layout_marginEnd="10dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filtrar por mi aula"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_active_classroom_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_gray"
                android:textSize="11sp" />
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_classroom_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:thumbTint="#BA1924"
            app:trackTint="@color/border_light" />
    </LinearLayout>

    <!-- Section Selector Dropdown (Admin/Prof) -->
    <LinearLayout
        android:id="@+id/layout_section_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:padding="12dp"
        android:background="@drawable/bg_card_row"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_person_placeholder"
            app:tint="@color/text_gray"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aula"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/menu_section_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="#BA1924"
            app:boxStrokeWidth="1dp"
            app:endIconTint="@color/text_gray"
            app:hintEnabled="false">

            <AutoCompleteTextView
                android:id="@+id/dropdown_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textColor="@color/text_white"
                android:textSize="13sp"
                android:singleLine="true"
                android:paddingVertical="8dp"
                android:gravity="center_vertical"
                android:background="@android:color/transparent"
                android:dropDownHeight="200dp"
                tools:text="Todos los salones" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Podium Section -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/podium_container"
                    android:layout_width="match_parent"
                    android:layout_height="310dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <!-- Rank 2 - Silver (Left) -->
                    <LinearLayout
                        android:id="@+id/col_rank_2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toLeftOf="@id/col_rank_1"
                        app:layout_constraintHorizontal_weight="1.0">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_silver"
                            android:padding="2dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_circle_default">

                                <TextView
                                    android:id="@+id/podium_avatar_text_2"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:textColor="@color/black"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </FrameLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/podium_name_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="1dp">

                            <TextView
                                android:id="@+id/podium_score_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/silver_crown"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/podium_suffix_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_gray"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/podium_trend_capsule_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_trend_up_capsule"
                            android:visibility="invisible">

                            <ImageView
                                android:id="@+id/podium_trend_icon_2"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:src="@drawable/ic_trend_up" />

                            <TextView
                                android:id="@+id/podium_trend_text_2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:textColor="@color/emerald"
                                android:textSize="8sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <FrameLayout android:layout_width="match_parent" android:layout_height="100dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_3d_podium_silver_front" />
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_3d_podium_silver_top" />
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center_horizontal|bottom"
                                android:layout_marginBottom="12dp"
                                android:src="@drawable/ic_trophy_badge_2" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Rank 1 - Gold (Center) -->
                    <LinearLayout
                        android:id="@+id/col_rank_1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:elevation="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toRightOf="@id/col_rank_2"
                        app:layout_constraintRight_toLeftOf="@id/col_rank_3"
                        app:layout_constraintHorizontal_weight="1.15">

                        <FrameLayout
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:background="@drawable/bg_circle_gold"
                            android:padding="2dp">

                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_circle_default">

                                <TextView
                                    android:id="@+id/podium_avatar_text_1"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:textColor="@color/black"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />
                            </FrameLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/podium_name_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="1dp">

                            <TextView
                                android:id="@+id/podium_score_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/gold_crown"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/podium_suffix_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_gray"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/podium_trend_capsule_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_trend_stable_capsule"
                            android:visibility="invisible">

                            <ImageView
                                android:id="@+id/podium_trend_icon_1"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:src="@drawable/ic_stable_gray" />
                            <TextView
                                android:id="@+id/podium_trend_text_1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:textColor="@color/text_gray"
                                android:textSize="8sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <FrameLayout android:layout_width="match_parent" android:layout_height="140dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_3d_podium_gold_front" />
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_3d_podium_gold_top" />
                            <ImageView
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:layout_gravity="center_horizontal|bottom"
                                android:layout_marginBottom="16dp"
                                android:src="@drawable/ic_trophy_badge_1" />
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Rank 3 - Bronze (Right) -->
                    <LinearLayout
                        android:id="@+id/col_rank_3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintLeft_toRightOf="@id/col_rank_1"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintHorizontal_weight="1.0">

                        <FrameLayout
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_circle_bronze"
                            android:padding="2dp">
                            <FrameLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/bg_circle_default">
                                <TextView
                                    android:id="@+id/podium_avatar_text_3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_gravity="center"
                                    android:textColor="@color/black"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </FrameLayout>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/podium_name_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/text_white"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="1dp">
                            <TextView
                                android:id="@+id/podium_score_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/bronze_crown"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/podium_suffix_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_gray"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/podium_trend_capsule_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="8dp"
                            android:background="@drawable/bg_trend_down_capsule"
                            android:visibility="invisible">

                            <ImageView
                                android:id="@+id/podium_trend_icon_3"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:src="@drawable/ic_trend_down" />
                            <TextView
                                android:id="@+id/podium_trend_text_3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:textColor="@color/neon_pink"
                                android:textSize="8sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <FrameLayout android:layout_width="match_parent" android:layout_height="75dp">
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="12dp"
                                android:background="@drawable/bg_3d_podium_bronze_front" />
                            <View
                                android:layout_width="match_parent"
                                android:layout_height="24dp"
                                android:background="@drawable/bg_3d_podium_bronze_top" />
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center_horizontal|bottom"
                                android:layout_marginBottom="8dp"
                                android:src="@drawable/ic_trophy_badge_3" />
                        </FrameLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Error / Empty state -->
                <TextView
                    android:id="@+id/tv_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text_gray"
                    android:textSize="16sp"
                    android:layout_marginTop="32dp"
                    android:visibility="gone" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider_color"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginVertical="12dp" />

                <!-- Remaining List (Ranks 4+) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view_leaderboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginHorizontal="16dp"
                    tools:listitem="@layout/item_leaderboard" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- Loading indicator overlay -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone" />
</FrameLayout>
