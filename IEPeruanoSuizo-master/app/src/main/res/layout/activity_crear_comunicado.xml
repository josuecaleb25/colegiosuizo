<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="30dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btn_back"
            android:layout_width="45dp"
            android:layout_height="45dp"
            app:cardBackgroundColor="?attr/homeContentBackground"
            app:cardCornerRadius="15dp"
            app:cardElevation="0dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center"
                android:src="@drawable/righticon"
                app:tint="#444444" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tv_title_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/potanosansbold"
            android:text="Crear comunicado"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginHorizontal="70dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppinsregular"
                android:text="Escribe el comunicado que deseas publicar"
                android:textColor="#5E5F60"
                android:textSize="13sp" />

            <!-- Asunto -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppinssemibold"
                android:text="Asunto:"
                android:textColor="#BA1924"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_asunto"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_border_selector"
                android:fontFamily="@font/poppinsregular"
                android:paddingHorizontal="16dp"
                android:textColor="#141A1E"
                android:textSize="14sp"
                android:inputType="textCapSentences" />

            <!-- Descripcion -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppinssemibold"
                android:text="Descripcion:"
                android:textColor="#BA1924"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_border_selector"
                android:fontFamily="@font/poppinsregular"
                android:gravity="top"
                android:minHeight="100dp"
                android:padding="16dp"
                android:textColor="#141A1E"
                android:textSize="14sp"
                android:inputType="textMultiLine|textCapSentences" />

            <!-- Destinatarios -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppinssemibold"
                android:text="Seleccionar Destinatarios:"
                android:textColor="#BA1924"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#BA1924"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <Spinner
                    android:id="@+id/spinner_destinatarios"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp"
                    android:backgroundTint="@android:color/white"
                    android:overlapAnchor="false"
                    android:spinnerMode="dropdown"
                    android:dropDownVerticalOffset="50dp"
                    android:dropDownHeight="160dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Adjuntar Imagen -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppinssemibold"
                android:text="Adjuntar Imagen:"
                android:textColor="#BA1924"
                android:textSize="14sp" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btn_adjuntar_imagen"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_border_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerInside"
                    android:padding="40dp"
                    android:src="@android:drawable/ic_menu_gallery"
                    app:tint="#9BA8AB" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enviar"
                android:layout_width="120dp"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:layout_gravity="end"
                android:text="Crear"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:fontFamily="@font/poppinssemibold"
                android:backgroundTint="#BA1924"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/bottomNavBackground"
        app:elevation="0dp"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/nav_item_color_state"
        app:itemActiveIndicatorStyle="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
