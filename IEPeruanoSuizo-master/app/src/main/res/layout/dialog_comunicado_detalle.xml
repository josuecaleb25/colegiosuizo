<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: título + logo -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/iv_logo_ieps"
                android:layout_width="48dp"
                android:layout_height="30dp"
                android:layout_marginEnd="0dp"
                android:src="@drawable/logoie"
                android:scaleType="fitCenter"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tv_titulo_detalle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Título del Comunicado"
                android:textColor="#BA1924"
                android:textSize="18sp"
                android:fontFamily="@font/poppinssemibold"
                android:lineSpacingExtra="2dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/iv_logo_ieps" />

            <!-- Fecha formateada (e.g. "Lunes, 19 de Mayo") -->
            <TextView
                android:id="@+id/tv_fecha_detalle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Lunes, 19 de Mayo"
                android:textColor="#9BA8AB"
                android:textSize="12sp"
                android:fontFamily="@font/poppinsmedium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_titulo_detalle"
                app:layout_constraintEnd_toStartOf="@+id/iv_logo_ieps" />

            <!-- Hora -->
            <TextView
                android:id="@+id/tv_hora_detalle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="10:30 AM"
                android:textColor="#BA1924"
                android:textSize="11sp"
                android:fontFamily="@font/poppinsmedium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_fecha_detalle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="20dp"
            android:background="#F0F0F0" />

        <!-- Contenido scrolleable -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/tv_contenido_detalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Contenido completo del mensaje..."
                    android:textColor="#5E5F60"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="@font/poppinsregular" />

                <!-- Tag salón (al fondo del contenido) -->
                <TextView
                    android:id="@+id/tv_tag_detalle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Salón: 4to A"
                    android:textColor="#90A5B4"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppinsmedium"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</androidx.cardview.widget.CardView>
