<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".AuthRegister">

        <include
            android:id="@+id/include_actionbar"
            layout="@layout/app_actionbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent" />


        <TextView
            android:id="@+id/WelcomeRegister"
            android:text="Te damos la bienvenida,"
            android:fontFamily="@font/poppinssemibold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            android:textColor="#BA1924"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintWidth_max="500dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/include_actionbar" />

        <TextView
            android:id="@+id/DescripRegister"
            android:text="Primero, busquemos tu nombre en la lista del colegio"
            android:fontFamily="@font/poppinsmedium"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#A8A7B2"
            android:layout_marginStart="25dp"
            android:layout_marginEnd="25dp"
            android:textSize="11sp"
            app:layout_constraintWidth_max="500dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/WelcomeRegister" />

        <ImageView
            android:id="@+id/ImageRegister"
            android:src="@drawable/registerimage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintWidth_percent="0.7"
            app:layout_constraintWidth_max="350dp"
            app:layout_constraintTop_toBottomOf="@+id/DescripRegister" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutlvleducativo"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="32dp"
            android:hint="Nivel Educativo"
            android:textColorHint="@color/input_border_selector"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:boxStrokeWidthFocused="2dp"
            app:boxCornerRadiusBottomEnd="25dp"
            app:boxCornerRadiusBottomStart="25dp"
            app:boxCornerRadiusTopEnd="25dp"
            app:boxCornerRadiusTopStart="25dp"
            app:boxStrokeColor="@color/input_border_selector"
            app:endIconDrawable="@drawable/ic_chevron_down"
            app:endIconTint="@color/inputcolorgris"
            app:layout_constraintWidth_max="450dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ImageRegister">

            <AutoCompleteTextView
                android:id="@+id/txtlvleducativo"
                android:layout_width="match_parent"
                android:fontFamily="@font/poppinsmedium"
                android:textSize="14sp"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:padding="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutturno"
            android:layout_marginStart="32dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="32dp"
            android:hint="Turno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColorHint="@color/input_border_selector"
            app:boxStrokeWidthFocused="2dp"
            app:boxCornerRadiusBottomEnd="25dp"
            app:boxCornerRadiusBottomStart="25dp"
            app:boxCornerRadiusTopEnd="25dp"
            app:boxCornerRadiusTopStart="25dp"
            app:boxStrokeColor="@color/input_border_selector"
            app:endIconDrawable="@drawable/ic_chevron_down"
            app:endIconTint="@color/inputcolorgris"
            app:layout_constraintWidth_max="450dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutlvleducativo" >

            <AutoCompleteTextView
                android:id="@+id/txtturno"
                android:inputType="none"
                android:fontFamily="@font/poppinsmedium"
                android:textSize="14sp"
                android:padding="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </com.google.android.material.textfield.TextInputLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/rowGradoSeccion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintWidth_max="450dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutturno">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutgrado"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="32dp"
                android:layout_marginEnd="8dp"
                android:hint="Grado"
                android:textColorHint="@color/input_border_selector"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusBottomEnd="25dp"
                app:boxCornerRadiusBottomStart="25dp"
                app:boxCornerRadiusTopEnd="25dp"
                app:boxCornerRadiusTopStart="25dp"
                app:boxStrokeColor="@color/input_border_selector"
                app:endIconDrawable="@drawable/ic_chevron_down"
                app:endIconTint="@color/inputcolorgris"
                app:layout_constraintEnd_toStartOf="@+id/layoutseccion"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <AutoCompleteTextView
                    android:id="@+id/txtgrado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppinsmedium"
                    android:textSize="14sp"
                    android:inputType="none"
                    android:padding="16dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layoutseccion"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="32dp"
                android:hint="Sección"
                android:textColorHint="@color/input_border_selector"
                app:boxStrokeWidthFocused="2dp"
                app:boxCornerRadiusBottomEnd="25dp"
                app:boxCornerRadiusBottomStart="25dp"
                app:boxCornerRadiusTopEnd="25dp"
                app:boxCornerRadiusTopStart="25dp"
                app:boxStrokeColor="@color/input_border_selector"
                app:endIconDrawable="@drawable/ic_chevron_down"
                app:endIconTint="@color/inputcolorgris"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/layoutgrado"
                app:layout_constraintTop_toTopOf="parent">

                <AutoCompleteTextView
                    android:id="@+id/txtseccion"
                    android:layout_width="match_parent"
                    android:fontFamily="@font/poppinsmedium"
                    android:textSize="14sp"
                    android:layout_height="wrap_content"
                    android:inputType="none"
                    android:padding="16dp" />

            </com.google.android.material.textfield.TextInputLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutalumno"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="32dp"
            android:hint="Alumno"
            android:textColorHint="@color/input_border_selector"
            app:boxStrokeWidthFocused="2dp"
            app:boxCornerRadiusBottomEnd="25dp"
            app:boxCornerRadiusBottomStart="25dp"
            app:boxCornerRadiusTopEnd="25dp"
            app:boxCornerRadiusTopStart="25dp"
            app:boxStrokeColor="@color/input_border_selector"
            app:endIconDrawable="@drawable/ic_chevron_down"
            app:endIconTint="@color/inputcolorgris"
            app:layout_constraintWidth_max="450dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rowGradoSeccion">

            <AutoCompleteTextView
                android:id="@+id/txtalumno"
                android:layout_width="match_parent"
                android:fontFamily="@font/poppinsmedium"
                android:textSize="14sp"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:padding="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSiguiente1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#BA1924"
            android:fontFamily="@font/poppinssemibold"
            android:textSize="16sp"
            android:text="Siguiente"
            android:textColor="@color/white"
            app:cornerRadius="15dp"
            app:layout_constraintWidth_max="450dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutalumno" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnSiguiente1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tienes una cuenta? "
                android:fontFamily="@font/poppinsmedium"
                android:textColor="#0E0D18"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvLoginFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar sesion"
                android:textColor="#BA1924"
                android:fontFamily="@font/poppinssemibold"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>