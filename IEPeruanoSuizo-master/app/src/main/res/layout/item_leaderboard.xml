<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:padding="12dp">

        <!-- Position number -->
        <TextView
            android:id="@+id/tv_position"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:fontFamily="@font/poppinsbold"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/circle_red"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="1" />

        <!-- Student name -->
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/poppinssemibold"
            android:textColor="#2D2D2D"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tv_position"
            app:layout_constraintTop_toTopOf="@id/tv_position"
            tools:text="Sebastián López" />

        <!-- Percentage badge -->
        <TextView
            android:id="@+id/tv_percentage"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:fontFamily="@font/poppinsbold"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_percentage"
            app:layout_constraintBottom_toBottomOf="@id/tv_position"
            app:layout_constraintStart_toStartOf="@id/tv_name"
            tools:text="95%" />

        <!-- Stats detail -->
        <TextView
            android:id="@+id/tv_stats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppinsregular"
            android:textColor="#9E9E9E"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_percentage"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_percentage"
            tools:text="8/10 puntual" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
